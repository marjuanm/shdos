###############################################################################
# ShellDOS - Git Attributes
###############################################################################

# All text files are stored as LF.
* text=auto eol=lf

###############################################################################
# Source code files
###############################################################################

*.c           text
*.h           text
*.cpp         text
*.hpp         text
*.asm         text
*.inc         text
*.def         text
*.rc          text
*.mak         text
*.mk          text
Makefile      text
*.txt         text
*.md          text
*.ini         text
*.cfg         text
*.gitignore   text
*.gitattributes text
*.editorconfig text
LICENSE       text

###############################################################################
# Scripts
###############################################################################

*.sh          text eol=lf
*.bat         text eol=crlf
*.cmd         text eol=crlf

###############################################################################
# Proyectos OpenWatcom
###############################################################################

*.wpj         text

###############################################################################
# Binaries
###############################################################################

*.exe         binary
*.com         binary
*.dll         binary
*.lib         binary
*.obj         binary
*.o           binary
*.a           binary
*.so          binary
*.sys         binary
*.bin         binary
*.img         binary
*.iso         binary
*.zip         binary
*.7z          binary
*.gz          binary
*.png         binary
*.jpg         binary
*.ico         binary
